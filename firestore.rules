rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (UID from Auth)
    // Fields:
    //   - email: string (required)
    //   - products: list (required)
    //   - createdAt: timestamp
    //   - lastLogin: timestamp
    //
    // Collection: config
    // Document ID: main
    // Fields:
    //   - name: string
    //   - logoUrl: string
    //   - bannerUrl: string
    //   - primaryColor: string
    //   - accentColor: string
    //   - modules: list
    //   - upsellCourses: list
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "cdsmarketingg@gmail.com" && request.auth.token.email_verified == true);
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /config/main {
      allow read: if true; // Publicly readable to load the course
      allow write: if isAdmin();
    }

    match /webhook_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
